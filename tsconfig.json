{
  "files": [],
  "references": [
    {
      "path": "./packages/core"
    },
    {
      "path": "./packages/connectors"
    },
    {
      "path": "./packages/agents"
    },
    {
      "path": "./packages/orchestrator"
    },
    {
      "path": "./packages/api"
    },
    {
      "path": "./packages/web"
    }
  ],
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "6.0",
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@digital-life/core": ["packages/core/src/index.ts"],
      "@digital-life/connectors": ["packages/connectors/src/index.ts"],
      "@digital-life/agents": ["packages/agents/src/index.ts"],
      "@digital-life/orchestrator": ["packages/orchestrator/src/index.ts"],
      "@digital-life/api": ["packages/api/src/index.ts"],
      "@digital-life/web": ["packages/web/src/main.tsx"]
    }
  }
}
