# Host-machine defaults for running services outside Compose.
# Compose files override these inside containers so services talk over the
# Compose network.
DATABASE_URL=postgres://digital_life:digital_life@localhost:5432/digital_life
DENSE_MEM_URL=http://localhost:8081
REDIS_URL=redis://localhost:6379
DIGITAL_LIFE_CONFIG_PATH=config/digital-life.yaml

PORT=3000

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_MODEL=gpt-5.2
MCP_FILESYSTEM_ROOT=/data
INTERNAL_API_TARGET=http://localhost:3000
VITE_API_PROXY_TARGET=http://localhost:3000
